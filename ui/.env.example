# Vite dev server port.
SMAILNAIL_UI_DEV_PORT=5050

# Backend proxy target. Prefer the full URL when the backend is remote or HTTPS.
# SMAILNAIL_UI_BACKEND_URL=http://localhost:8080

# Or override the backend pieces individually for local development.
SMAILNAIL_UI_BACKEND_PROTOCOL=http
SMAILNAIL_UI_BACKEND_HOST=localhost
SMAILNAIL_UI_BACKEND_PORT=8080
